//- nav.navigation.preloading
nav.navigation
    .navigation_wrapper    
        .navigation_logo
            a.navigation_logo_wrapper(href="/")
                p=navigation.logo.topText
                p.copyright ©
                p=navigation.logo.bottomText

        .navigation_content
            .navigation_content_wrapper     
                span=navigation.availability
                a(href=`mailto:${navigation.contact.email}`)
                    span=navigation.contact.email
                a(href=`tel:${navigation.contact.phone}`)
                    span=navigation.contact.phone

        .navigation_services
            .navigation_services_wrapper     
                each service in navigation.services
                    span= service

        .navigation_social     
            .navigation_social_wrapper     
                span Social:
                .social_wrapper     
                    each social in navigation.socials
                        a(href=social.url) 
                            span= social.label

        .navigation_menu     
            a(href=navigation.menuLinks.workLabel class=(page === 'home' ? 'active' : ''))
                svg(xmlns='http://www.w3.org/2000/svg' width='9' height='7' viewbox='0 0 9 7' fill='none' )
                    path(d='M8.69387 3.69631C8.87294 3.51724 8.87294 3.2269 8.69387 3.04783L5.77572 0.129688C5.59665 -0.0493837 5.30632 -0.0493837 5.12725 0.129688C4.94817 0.30876 4.94817 0.599093 5.12725 0.778165L7.72115 3.37207L5.12725 5.96598C4.94817 6.14505 4.94817 6.43538 5.12725 6.61445C5.30632 6.79353 5.59665 6.79353 5.77572 6.61445L8.69387 3.69631ZM0.3396 3.83061L8.36963 3.83061L8.36963 2.91353L0.3396 2.91353L0.3396 3.83061Z' fill='currentColor')
                span WRK
            a(href=navigation.menuLinks.aboutLabel class=(page === 'about' ? 'active' : ''))
                svg(xmlns='http://www.w3.org/2000/svg' width='9' height='7' viewbox='0 0 9 7' fill='none' )
                    path(d='M8.69387 3.69631C8.87294 3.51724 8.87294 3.2269 8.69387 3.04783L5.77572 0.129688C5.59665 -0.0493837 5.30632 -0.0493837 5.12725 0.129688C4.94817 0.30876 4.94817 0.599093 5.12725 0.778165L7.72115 3.37207L5.12725 5.96598C4.94817 6.14505 4.94817 6.43538 5.12725 6.61445C5.30632 6.79353 5.59665 6.79353 5.77572 6.61445L8.69387 3.69631ZM0.3396 3.83061L8.36963 3.83061L8.36963 2.91353L0.3396 2.91353L0.3396 3.83061Z' fill='currentColor')
                span ABT

        .navigation_hamburger
            span.line.top_line
            span.line.bottom_line



    .navigation_content_wrapper(style='background-color: ' + (colors && colors.backgroundColor))     
        .navigation_content
            .navigation_menu     
                a.menu_link(href=navigation.menuLinks.workLabel class=(page === 'home' ? 'active' : ''))
                    svg.relative.left-0.will-change-transform.transition-trop.duration-500(xmlns='http://www.w3.org/2000/svg' width='54' height='42' viewbox='0 0 9 7' fill='none' class='top-1/2 group-not-active:opacity-0 group-not-active:translate-x-[25%] xs1:mr-md1 sm1:mr-xl1')
                        path(d='M8.69387 3.69631C8.87294 3.51724 8.87294 3.2269 8.69387 3.04783L5.77572 0.129688C5.59665 -0.0493837 5.30632 -0.0493837 5.12725 0.129688C4.94817 0.30876 4.94817 0.599093 5.12725 0.778165L7.72115 3.37207L5.12725 5.96598C4.94817 6.14505 4.94817 6.43538 5.12725 6.61445C5.30632 6.79353 5.59665 6.79353 5.77572 6.61445L8.69387 3.69631ZM0.3396 3.83061L8.36963 3.83061L8.36963 2.91353L0.3396 2.91353L0.3396 3.83061Z' fill='currentColor')

                    h1 WRK
                a.menu_link(href=navigation.menuLinks.aboutLabel class=(page === 'about' ? 'active' : ''))
                    svg.relative.left-0.will-change-transform.transition-trop.duration-500(xmlns='http://www.w3.org/2000/svg' width='54' height='42' viewbox='0 0 9 7' fill='none' class='top-1/2 group-not-active:opacity-0 group-not-active:translate-x-[25%] xs1:mr-md1 sm1:mr-xl1')
                        path(d='M8.69387 3.69631C8.87294 3.51724 8.87294 3.2269 8.69387 3.04783L5.77572 0.129688C5.59665 -0.0493837 5.30632 -0.0493837 5.12725 0.129688C4.94817 0.30876 4.94817 0.599093 5.12725 0.778165L7.72115 3.37207L5.12725 5.96598C4.94817 6.14505 4.94817 6.43538 5.12725 6.61445C5.30632 6.79353 5.59665 6.79353 5.77572 6.61445L8.69387 3.69631ZM0.3396 3.83061L8.36963 3.83061L8.36963 2.91353L0.3396 2.91353L0.3396 3.83061Z' fill='currentColor')
                    h1 ABT

            .navigation_contact
                span=navigation.availability
                a(href=`mailto:${navigation.contact.email}`)
                    span=navigation.contact.email
                a(href=`tel:${navigation.contact.phone}`)
                    span=navigation.contact.phone

            .navigation_services
                each service in navigation.services
                    span= service

            .navigation_social     
                span Social:
                .social_link_wrapper     
                    each social in navigation.socials
                        a(href=social.url) 
                            span= social.label
