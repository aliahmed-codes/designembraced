block variables
doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Design Embraced

    link(rel="stylesheet" href="/css/main.css")

  body(style='background-color: ' + (colors && colors.backgroundColor) + '; color: ' + (colors && colors.textColor))
    include ./partials/preloader
    include ./partials/navigation

    .content#content(data-template=template data-backgroundColor=colors.backgroundColor data-color=colors.textColor)
      block content

    include ./partials/footer
    script.  
      window.ASSETS = !{JSON.stringify(assets).replace(/<\//g, "<\\/")}
    script(src="/js/app.js")